        {
          "name": "POST Add Fund Usage \u00e2\u20ac\u201d overspend (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for overspend', () => pm.response.to.have.status(400));",
                  "pm.test('Error mentions overspend or exceeds', () => {",
                  "  const err = pm.response.json().error || '';",
