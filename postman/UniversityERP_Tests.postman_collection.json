{
  "info": {
    "_postman_id": "udiims-collection-v1",
    "name": "UDIIMS University ERP \u00e2\u20ac\u201d Full API Test Suite",
    "description": "Comprehensive REST API tests for all 14 use cases in UDIIMS.\nCovers Students, Courses, Enrollment, GPA, Fees, Finance, Secretary, and Department Funds.\n\nEnvironment: ERP Local Environment\nBase URL: {{baseUrl}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "UC-01 \u00e2\u20ac\u201d Student Profile",
      "item": [
        {
          "name": "GET Student by ID (valid)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has student_id', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.student_id).to.eql(pm.environment.get('studentId'));",
                  "});",
                  "pm.test('Has student_name', () => pm.expect(pm.response.json().student_name).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/students/{{studentId}}"
          }
        },
        {
          "name": "GET Student by ID (invalid \u00e2\u20ac\u201d expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Has error field', () => pm.expect(pm.response.json().error).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/students/INVALID_ID_999"
          }
        }
      ]
    },
    {
